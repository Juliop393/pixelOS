# Supabase
NEXT_PUBLIC_SUPABASE_URL=tu-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-supabase-anon-key
# SECRETA: solo servidor. Usada por el webhook para escribir saltándose RLS.
SUPABASE_SERVICE_ROLE_KEY=tu-supabase-service-role-key

# n8n
NEXT_PUBLIC_N8N_WEBHOOK_URL=tu-n8n-webhook-url

# Lemon Squeezy
LEMONSQUEEZY_API_KEY=tu-lemonsqueezy-api-key
# SECRETA: usada para verificar la firma X-Signature de los webhooks.
LEMONSQUEEZY_WEBHOOK_SECRET=tu-lemonsqueezy-webhook-secret
# Base del store (Settings -> Domains en Lemon Squeezy), ej: https://tutienda.lemonsqueezy.com
NEXT_PUBLIC_LEMONSQUEEZY_STORE_URL=https://tutienda.lemonsqueezy.com
